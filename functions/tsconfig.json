{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "Bundler",
        "lib": [
            "ESNext"
        ],
        "types": [
            "@cloudflare/workers-types"
        ],
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "removeComments": true,
        "noImplicitAny": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "api/**/*.ts",
        "worker-configuration.d.ts",
        "../assets/ts/interfaces.d.ts"
    ],
    "exclude": [
        "test/**/*"
    ]
}