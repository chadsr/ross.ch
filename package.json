{
    "name": "ross.ch",
    "version": "2.0.0",
    "description": "ross.ch website",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "hugo --minify && npm run build:functions",
        "build:functions": "wrangler pages functions build --minify --outdir=./dist/worker/",
        "lint": "eslint . && stylelint **/*.scss",
        "format": "eslint --fix . && stylelint --fix **/*.scss",
        "prepare": "husky",
        "dev": "hugo --logLevel debug server --ignoreCache --disableFastRender",
        "dev:wrangler": "wrangler dev",
        "dev-host": "hugo --logLevel debug server --ignoreCache --disableFastRender --bind 0.0.0.0",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "cf-deploy": "wrangler deploy",
        "cf-dev": "wrangler pages dev",
        "cf-typegen": "wrangler types functions/worker-configuration.d.ts",
        "deploy-fleek": "fleek sites deploy"
    },
    "keywords": [],
    "author": "Ross Chadwick",
    "license": "GPL-3.0-only",
    "browserslist": [
        "defaults",
        "iOS >= 14",
        "ChromeAndroid >= 119"
    ],
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "^0.17.0",
        "@cloudflare/workers-types": "^4.20260519.1",
        "@eslint/js": "^10.0.1",
        "@fontsource-variable/space-grotesk": "^5.2.10",
        "@fullhuman/postcss-purgecss": "^8.0.0",
        "@openpgp/web-stream-tools": "^0.3.1",
        "@vitest/coverage-istanbul": "^4.1.6",
        "autoprefixer": "^10.5.0",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "husky": "^9.1.7",
        "node-addon-api": "^8.8.0",
        "postcss": "^8.5.15",
        "postcss-calc": "^10.1.1",
        "postcss-cli": "^11.0.1",
        "postcss-preset-env": "^11.3.0",
        "postcss-scss": "^4.0.9",
        "prettier": "^3.8.3",
        "stylelint": "^17.11.1",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-prettier": "^5.0.3",
        "stylelint-scss": "^7.2.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vitest": "^4.1.6",
        "wrangler": "^4.103.0"
    },
    "dependencies": {
        "axios": "^1.16.1",
        "openpgp": "^6.3.0",
        "resend": "^6.12.4"
    }
}
